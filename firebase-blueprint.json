{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile synchronized from Auth.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique Firebase Auth identifier."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's registered email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user registered/synced."
        }
      },
      "required": ["uid", "email"]
    },
    "EscalatedCase": {
      "title": "Escalated Case",
      "description": "Diagnostic reports or cases of crop diseases.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the case."
        },
        "userUid": {
          "type": "string",
          "description": "UID of the user who submitted the case, if signed in."
        },
        "districtId": {
          "type": "string",
          "description": "District code identifier."
        },
        "farmerName": {
          "type": "string",
          "description": "Name of the farmer."
        },
        "village": {
          "type": "string",
          "description": "Village name."
        },
        "cropName": {
          "type": "string",
          "description": "Name of the crop."
        },
        "photoThumbnail": {
          "type": "string",
          "description": "Data URL or image URL."
        },
        "diagnosis": {
          "type": "object",
          "description": "Diagnosis object containing disease, confidence, recommendations."
        },
        "symptomDescription": {
          "type": "string",
          "description": "Text description of symptoms."
        },
        "voiceTranscript": {
          "type": "string",
          "description": "Optional voice recording transcription."
        },
        "submissionTime": {
          "type": "string",
          "format": "date-time",
          "description": "Submission date-time."
        },
        "status": {
          "type": "string",
          "description": "Status of the case (Open, In Review, Responded, Closed)."
        },
        "advisoryResponse": {
          "type": "string",
          "description": "Official advisory recommendations response."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Database insertion timestamp."
        }
      },
      "required": [
        "id",
        "districtId",
        "farmerName",
        "village",
        "cropName",
        "symptomDescription",
        "submissionTime",
        "status"
      ]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Store user profiles sync'd from auth."
    },
    "escalatedCases/{caseId}": {
      "schema": "EscalatedCase",
      "description": "Crop disease case tracking and responses."
    }
  }
}
